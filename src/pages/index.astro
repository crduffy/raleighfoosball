---
import Base from '../layouts/Base.astro';
import { Image } from 'astro:assets';
import heroRoom from '../assets/hero-room.jpg';
import tornadoDoubles from '../assets/tornado-doubles.jpg';
import bonziniMatch from '../assets/bonzini-match.jpg';
import leagueGroup from '../assets/league-group.jpg';
import teamLegend from '../assets/team-legend.jpg';
import crewSmiles from '../assets/crew-smiles.jpg';
import worldsBalcony from '../assets/worlds-balcony.jpg';
import tornadoFocus from '../assets/tornado-focus.jpg';
import bonziniNight from '../assets/bonzini-night.jpg';
import bonziniCrowd from '../assets/bonzini-crowd.jpg';
import tornadoRow from '../assets/tornado-row.jpg';
---

<Base
  title="Powerkick | Raleigh Foosball"
  description="We play foosball Thursday and Friday nights at Snookers Billiards in Raleigh, NC. Weekly Tornado and Bonzini DYP tournaments — every skill level welcome, first-timers play free on Friday."
>
  <!-- ——— Hero ——— -->
  <section class="hero">
    <Image
      src={heroRoom}
      alt="A busy foosball night at Snookers Billiards — players at Tornado tables under the lights"
      class="hero-photo"
      widths={[640, 1080, 1600, 2000]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
    />
    <div class="hero-shade" aria-hidden="true"></div>
    <div class="wrap hero-content">
      <p class="eyebrow">Snookers Billiards · Raleigh, NC</p>
      <h1>
        Powerkick
        <span class="h1-sub hot">Raleigh Foosball</span>
      </h1>
      <p class="hero-sub">
        Fun. Family. Foosball. We play Thursday and Friday nights, every
        week. Five tables, cheap games, every skill level — and first-timers
        play Friday for free.
      </p>
      <div class="hero-cta">
        <a href="#nights" class="btn btn-solid">See the weekly nights</a>
        <a href="https://www.youtube.com/@raleighfoosball919" class="btn btn-ghost">Watch matches ↗</a>
      </div>
    </div>
  </section>

  <!-- ——— Table specs strip ——— -->
  <div class="specs" role="note" aria-label="Table information">
    <div class="wrap specs-inner mono">
      <span>3× Tornado T3000 · $1/game</span>
      <i aria-hidden="true"></i>
      <span>2× Bonzini B90 · $0.75/game</span>
      <i aria-hidden="true"></i>
      <span>All tables on coin play</span>
      <i aria-hidden="true"></i>
      <span>3520 Wade Ave</span>
    </div>
  </div>

  <!-- ——— Weekly nights ——— -->
  <section class="section" id="nights">
    <div class="wrap">
      <div class="section-head">
        <span class="eyebrow">Every week</span>
        <h2>Two nights.<br />Two tables.</h2>
      </div>

      <div class="nights-grid">
        <!-- Thursday · Tornado -->
        <article class="lit night-card">
          <div class="night-photo">
            <Image
              src={tornadoDoubles}
              alt="Doubles match on the Tornado table"
              widths={[480, 760, 1100]}
              sizes="(max-width: 900px) 100vw, 540px"
            />
            <span class="day-tag mono">Thursday</span>
          </div>
          <div class="night-body">
            <h3>Tornado DYP</h3>
            <dl class="mono night-data">
              <div><dt>Registration</dt><dd>7:30 pm</dd></div>
              <div><dt>Play starts</dt><dd>8:00 pm</dd></div>
              <div><dt>Entry</dt><dd>$5</dd></div>
              <div><dt>Format</dt><dd>Double elim · games to 5 · best 2 of 3</dd></div>
            </dl>
            <p class="muted">
              Draw Your Partner on the Tornado tables — you get randomly
              paired, so come solo and leave with a teammate.
            </p>
            <a href="https://www.facebook.com/groups/1040531949295319/" class="night-link">Join the Tornado Facebook group ↗</a>
          </div>
        </article>

        <!-- Friday · Bonzini -->
        <article class="lit night-card">
          <div class="night-photo">
            <Image
              src={bonziniMatch}
              alt="A Bonzini match under the Budweiser lamp"
              widths={[480, 760, 1100]}
              sizes="(max-width: 900px) 100vw, 540px"
            />
            <span class="day-tag mono">Friday</span>
          </div>
          <div class="night-body">
            <h3>Bonzini DYP</h3>
            <dl class="mono night-data">
              <div><dt>Registration</dt><dd>8:00 pm</dd></div>
              <div><dt>Play starts</dt><dd>8:30 pm</dd></div>
              <div><dt>Entry</dt><dd>$6 <span class="free-pill">First-timers free</span></dd></div>
              <div><dt>Format</dt><dd>Double elim · games to 5 · best 2 of 3</dd></div>
            </dl>
            <p class="muted">
              Our weekly DYP runs in an A/B format: the field is split by
              relative skill, and every “A” player is randomly paired with a
              “B” player. Whatever your level, you have a real shot.
            </p>
            <a href="https://www.facebook.com/groups/raleighfoosball/" class="night-link">Join the Raleigh Foosball Facebook group ↗</a>
          </div>
        </article>
      </div>

      <aside class="lit first-friday">
        <span class="day-tag mono ff-tag">First Friday</span>
        <div class="ff-body">
          <h3>Monthly multitable event</h3>
          <p class="muted">
            On the first Friday of every month, the night goes multitable —
            Tornado and Bonzini in one event. All five tables in play.
          </p>
        </div>
      </aside>
    </div>
  </section>

  <div class="wrap">
    <div class="scoreline" aria-hidden="true">
      <i></i><i></i><span class="rod"></span><i class="open"></i><i class="open"></i><i class="open"></i><i class="open"></i>
    </div>
  </div>

  <!-- ——— Values ——— -->
  <section class="section">
    <div class="wrap">
      <div class="section-head">
        <span class="eyebrow">What we're about</span>
        <h2>What Raleigh Foosball<br />is all about</h2>
      </div>

      <div class="values-grid">
        <div class="value">
          <h3>Nurture new players</h3>
          <p class="muted">
            At some point, every one of us was new to foosball. Whether it's
            your first tournament or your first in 10+ years, we want the
            Raleigh Foosball experience to be enjoyable for every player.
          </p>
        </div>
        <div class="value">
          <h3>Grow as a team</h3>
          <p class="muted">
            We all like to see our game improve. This group is always
            striving to learn, teach, and grow — whether you're chasing the
            number-one spot or just hitting the tables now and then, we raise
            everyone up together.
          </p>
        </div>
        <div class="value">
          <h3>Have fun</h3>
          <p class="muted">
            Listed last, but by far the most important. Fun is the core of
            Raleigh Foosball. Try hard, compete — but at the end of the
            night, if you're not having fun, everything else is meaningless.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ——— Gallery ——— -->
  <section class="section gallery-section">
    <div class="wrap">
      <div class="section-head">
        <span class="eyebrow">Around the tables</span>
        <h2>The crew</h2>
      </div>

      <div class="gallery">
        <Image src={bonziniCrowd} alt="A full crowd around the Bonzini tables on a DYP night" widths={[640, 1080, 1400]} sizes="(max-width: 700px) 100vw, 50vw" class="g-feature" />
        <Image src={tornadoRow} alt="Matches running down the row of Tornado tables" widths={[480, 760]} sizes="(max-width: 700px) 100vw, 25vw" class="g-tall" />
        <Image src={tornadoFocus} alt="Two players locked in at the Tornado table" widths={[480, 760]} sizes="(max-width: 700px) 100vw, 25vw" />
        <Image src={bonziniNight} alt="A crowd around the Bonzini table on a Friday night" widths={[480, 760]} sizes="(max-width: 700px) 100vw, 25vw" />
        <Image src={leagueGroup} alt="League night group photo at Snookers" widths={[480, 760, 960]} sizes="(max-width: 700px) 100vw, 25vw" />
        <Image src={teamLegend} alt="Team Legend after a league night" widths={[480, 760, 960]} sizes="(max-width: 700px) 100vw, 25vw" />
        <Image src={worldsBalcony} alt="Raleigh players at the World Championships in New Orleans" widths={[480, 760, 960]} sizes="(max-width: 700px) 100vw, 25vw" />
        <Image src={crewSmiles} alt="Friends between matches" widths={[480, 760]} sizes="(max-width: 700px) 100vw, 25vw" />
      </div>
    </div>
  </section>

  <!-- ——— Follow the action ——— -->
  <section class="section">
    <div class="wrap">
      <div class="section-head">
        <span class="eyebrow">Beyond the bar</span>
        <h2>Follow the action</h2>
      </div>

      <div class="follow-grid">
        <a href="https://stats.raleighfoosball.com" class="lit follow-card">
          <span class="mono follow-kicker">stats.raleighfoosball.com</span>
          <h3>League stats</h3>
          <p class="muted">Standings, results, and player records from our weekly nights.</p>
          <span class="follow-go" aria-hidden="true">→</span>
        </a>
        <a href="https://www.youtube.com/@raleighfoosball919" class="lit follow-card">
          <span class="mono follow-kicker">youtube.com/@raleighfoosball919</span>
          <h3>Match videos</h3>
          <p class="muted">Streams and recorded matches from tournament nights.</p>
          <span class="follow-go" aria-hidden="true">→</span>
        </a>
        <a href="/contact-us/" class="lit follow-card">
          <span class="mono follow-kicker">First time?</span>
          <h3>Come say hi</h3>
          <p class="muted">Questions about the nights, the tables, or where to start? We'd love to hear from you.</p>
          <span class="follow-go" aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>
</Base>

<style>
  /* ——— hero ——— */
  .hero {
    position: relative;
    min-height: min(92vh, 860px);
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .hero :global(.hero-photo) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
  }

  .hero-shade {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to top, var(--pitch) 6%, rgba(14, 17, 19, 0.78) 42%, rgba(14, 17, 19, 0.42) 100%),
      linear-gradient(100deg, rgba(10, 12, 14, 0.55) 0%, transparent 55%),
      radial-gradient(90% 60% at 50% 108%, rgba(255, 150, 60, 0.14), transparent 60%);
  }

  .hero-content {
    position: relative;
    padding-block: clamp(3.5rem, 9vw, 6.5rem);
    max-width: 100%;
    text-shadow: 0 1px 14px rgba(0, 0, 0, 0.45);
  }

  .hero-content .eyebrow {
    display: block;
    margin-bottom: 1.1rem;
    animation: rise 0.7s ease both;
  }

  .hero h1 {
    font-size: clamp(3.6rem, 11vw, 8rem);
    font-weight: 800;
    animation: rise 0.7s 0.08s ease both;
  }

  .hero h1 .hot { color: var(--rail); }

  .hero h1 .h1-sub {
    display: block;
    font-size: 0.42em;
    font-weight: 700;
    letter-spacing: 0.08em;
    margin-top: 0.18em;
  }

  .hero-sub {
    max-width: 34rem;
    margin-top: 1.3rem;
    font-size: 1.15rem;
    color: var(--chalk);
    animation: rise 0.7s 0.16s ease both;
  }

  .hero-cta {
    display: flex;
    gap: 0.9rem;
    margin-top: 2rem;
    flex-wrap: wrap;
    animation: rise 0.7s 0.24s ease both;
  }

  @keyframes rise {
    from { opacity: 0; transform: translateY(18px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ——— specs strip ——— */
  .specs {
    border-block: 1px solid var(--line);
    background: var(--pitch-deep);
  }

  .specs-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.2rem;
    flex-wrap: wrap;
    padding-block: 0.85rem;
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--smoke);
  }

  .specs-inner i {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--rail);
    opacity: 0.7;
  }

  /* ——— nights ——— */
  .nights-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(1.2rem, 3vw, 2rem);
  }

  .night-photo {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }

  .night-photo :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.92) contrast(1.04);
    transition: transform 0.5s ease;
  }

  .night-card:hover .night-photo :global(img) { transform: scale(1.03); }

  .day-tag {
    position: absolute;
    top: 0.9rem;
    left: 0.9rem;
    background: var(--pitch-deep);
    color: var(--rail-hot);
    border: 1px solid rgba(255, 122, 41, 0.45);
    padding: 0.3rem 0.7rem;
    border-radius: 4px;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .night-body { padding: clamp(1.3rem, 3vw, 2rem); }

  .night-body h3 { font-size: 2.1rem; margin-bottom: 1.2rem; }

  .night-data {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    margin-bottom: 1.2rem;
    font-size: 0.83rem;
  }

  .night-data > div {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    border-bottom: 1px dashed var(--line);
    padding-bottom: 0.45rem;
  }

  .night-data dt {
    color: var(--smoke);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-size: 0.72rem;
    padding-top: 0.15em;
    flex: none;
  }

  .night-data dd { text-align: right; color: var(--chalk); }

  .free-pill {
    display: inline-block;
    background: rgba(76, 194, 126, 0.14);
    color: var(--felt);
    border: 1px solid rgba(76, 194, 126, 0.4);
    border-radius: 999px;
    font-size: 0.68rem;
    padding: 0.1rem 0.55rem;
    margin-left: 0.4rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .night-body .muted { font-size: 0.97rem; margin-bottom: 1.1rem; }

  .night-link {
    font-weight: 600;
    font-size: 0.95rem;
  }

  /* ——— first friday ——— */
  .first-friday {
    margin-top: clamp(1.2rem, 3vw, 2rem);
    display: flex;
    align-items: center;
    gap: clamp(1.2rem, 3vw, 2.2rem);
    padding: clamp(1.3rem, 3vw, 1.8rem) clamp(1.3rem, 3vw, 2.2rem);
    flex-wrap: wrap;
  }

  .ff-tag {
    position: static;
    background: rgba(76, 194, 126, 0.12);
    color: var(--felt);
    border-color: rgba(76, 194, 126, 0.4);
    flex: none;
  }

  .ff-body h3 { font-size: 1.7rem; margin-bottom: 0.35rem; }
  .ff-body p { font-size: 0.98rem; max-width: 46rem; }

  /* ——— values ——— */
  .values-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1.5rem, 4vw, 3rem);
  }

  .value {
    border-top: 2px solid var(--rail);
    padding-top: 1.2rem;
  }

  .value h3 { font-size: 1.55rem; margin-bottom: 0.7rem; }
  .value p { font-size: 0.98rem; }

  /* ——— gallery ——— */
  .gallery-section { padding-top: 0; }

  .gallery {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 235px;
    grid-auto-flow: dense;
    gap: 0.9rem;
  }

  .gallery :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 8px;
    border: 1px solid var(--line);
    filter: saturate(0.95);
    transition: transform 0.35s ease, filter 0.35s ease;
  }

  .gallery :global(img:hover) {
    transform: translateY(-4px);
    filter: saturate(1.05);
  }

  .gallery :global(.g-tall) { grid-row: span 2; }

  .gallery :global(.g-feature) {
    grid-column: span 2;
    grid-row: span 2;
  }

  /* ——— follow ——— */
  .follow-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1rem, 2.5vw, 1.6rem);
  }

  .follow-card {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: clamp(1.3rem, 3vw, 1.8rem);
    color: var(--chalk);
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  .follow-card:hover {
    transform: translateY(-4px);
    border-color: rgba(255, 122, 41, 0.5);
    color: var(--chalk);
  }

  .follow-kicker {
    font-size: 0.7rem;
    color: var(--rail);
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .follow-card h3 { font-size: 1.7rem; }
  .follow-card p { font-size: 0.95rem; flex: 1; }

  .follow-go {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--rail);
    transition: transform 0.2s ease;
  }

  .follow-card:hover .follow-go { transform: translateX(6px); }

  /* ——— responsive ——— */
  @media (max-width: 900px) {
    .nights-grid { grid-template-columns: 1fr; }
    .follow-grid { grid-template-columns: 1fr; }
    .values-grid { grid-template-columns: 1fr; }
    .gallery {
      grid-template-columns: 1fr 1fr;
      grid-auto-rows: 200px;
    }
  }

  @media (max-width: 520px) {
    .gallery { grid-template-columns: 1fr; grid-auto-rows: 230px; }
    .gallery :global(.g-tall) { grid-row: span 1; }
    .gallery :global(.g-feature) { grid-column: span 1; grid-row: span 2; }
  }
</style>
